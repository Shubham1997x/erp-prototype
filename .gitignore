# ── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js ──────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ── Testing ──────────────────────────────────────────────────────────────────
/coverage

# ── Database (SQLite — never commit your production DB) ─────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite-shm
*.sqlite-wal

# ── Environment variables ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.development
.env.production

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo

# ── Misc ─────────────────────────────────────────────────────────────────────
*.pem
.vercel
